import pandas as pd
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression
import zipfile
# Path to ZIP file
url = r"C:\Users\omkat\Downloads\Energy Demand Forecasting.zip"
# Read CSV from ZIP
try:
with zipfile.ZipFile(url) as z:
file_name = z.namelist()[0]  # first file inside ZIP
data = pd.read_csv(z.open(file_name))
except Exception as e:
print("Error loading file:", e)
raise
# Show available columns
print("Available columns:", data.columns.tolist())
# Pick the first numeric column automatically if 'DOM_MW' not found
if 'DOM_MW' in data.columns:
temp_col = 'DOM_MW'
else:
temp_col = data.select_dtypes(include='number').columns[0]
print(f"Using numeric column: {temp_col}")
# Add time index
data['TimeIndex'] = range(len(data))
# Features and target
X = data[['TimeIndex']]
y = data[temp_col]
# Train linear regression model
model = LinearRegression()
model.fit(X, y)
# Predict next two steps
future_steps = pd.DataFrame({'TimeIndex': [len(data), len(data) + 1]})
pred = model.predict(future_steps)
print("Predicted values for next two steps:")
print(pred)
# Plot results
plt.figure(figsize=(12, 6))
plt.plot(data['TimeIndex'], y, label='Actual Data', alpha=0.5)
plt.plot(data['TimeIndex'], model.predict(X), color='orange', label='Regression 
plt.scatter(future_steps['TimeIndex'], pred, color='red', zorder=5, label='Futur
plt.xlabel("Time Index")
plt.ylabel(temp_col)
plt.title("Energy Demand Forecasting")
plt.legend()
plt.grid(True)
plt.show()