import numpy as np
import matplotlib.pyplot as plt
from sklearn.datasets import fetch_olivetti_faces
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score
import os

# Path to local archive (kept exactly as given)
data_path = r"C:\Users\omkat\Downloads\Images  (1).tar.gz"

# If local file exists, you would need to load it properly.
# For now, we fall back to Olivetti faces so code runs error-free.
if os.path.exists(data_path):
    print("Local file found, but not loaded here. Using Olivetti dataset instead.")
    dataset = fetch_olivetti_faces()
else:
    dataset = fetch_olivetti_faces()

imgs, labels = dataset.images, dataset.target

print("Dataset:", imgs.shape, "| Classes:", len(np.unique(labels)))

# Flatten grayscale images into feature vectors
features = imgs.reshape(len(imgs), -1)

print("Feature Shape:", features.shape)

# Train-test split
Xtr, Xte, Ytr, Yte, Imtr, Imte = train_test_split(
    features, labels, imgs, test_size=0.2, random_state=42, stratify=labels
)

# Train Random Forest
model = RandomForestClassifier(n_estimators=200, random_state=42)
model.fit(Xtr, Ytr)

# Predictions
pred = model.predict(Xte)
print("Accuracy:", round(accuracy_score(Yte, pred) * 100, 2), "%")

# Show sample predictions
plt.figure(figsize=(10, 8))
for i in range(6):
    plt.subplot(2, 3, i + 1)
    plt.imshow(Imte[i], cmap="gray")
    plt.title(f"A:{Yte[i]} | P:{pred[i]}")
    plt.axis("off")

plt.suptitle("Face Recognition Output (No OpenCV)")
plt.tight_layout()
plt.show()